generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SubscriptionTier {
  id            String         @id @default(cuid())
  name          String         @unique
  type          String         @unique
  totalRequests Int            @map("total_requests")
  price         String
  validityDays  Int            @map("validity_days")
  currency      String         @default("INR")
  description   String?
  features      String[]
  Subscription  Subscription[]

  @@index([name])
  @@index([type])
  @@map("subscription_tiers")
}

model User {
  id          String   @id @default(cuid())
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  email       String   @unique
  age         Int?
  phoneNumber String   @unique @map("phone_number")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Current active subscription tracking
  activeSubscriptionId String? @unique @map("active_subscription_id")
  requestsUsedLifetime Int     @default(0) @map("requests_used_lifetime")

  // Relations
  Thread       Thread[]
  userMemory   UserMemory?
  payments     Payment[]
  Subscription Subscription[]
  OtpCode      OtpCode[]

  @@index([email])
  @@index([activeSubscriptionId])
  @@map("users")
}

model OtpCode {
  id          String   @id @default(cuid())
  userId      String?
  phoneNumber String
  code        String
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber])
  @@index([code])
}

model Subscription {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  tierId   String @map("tier_id")
  planType String @map("plan_type")
  amount   String
  currency String @default("INR")

  // Request quota for THIS subscription
  totalRequests Int @map("total_requests")
  requestsUsed  Int @default(0) @map("requests_used")

  // Subscription validity
  startDate   DateTime? @map("start_date")
  expiresAt   DateTime? @map("expires_at")
  cancelledAt DateTime? @map("cancelled_at")

  status    SubscriptionStatus @default(PENDING)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier     SubscriptionTier @relation(fields: [tierId], references: [id], onDelete: Restrict)
  payments Payment[]

  @@index([userId])
  @@index([tierId])
  @@index([status])
  @@index([expiresAt])
  @@map("subscriptions")
}

model Payment {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  subscriptionId    String        @map("subscription_id")
  razorpayPaymentId String?       @unique @map("razorpay_payment_id")
  razorpayOrderId   String?       @map("razorpay_order_id")
  razorpaySignature String?       @map("razorpay_signature")
  amount            String
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  method            String?
  description       String?
  notes             Json?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([razorpayPaymentId])
  @@map("payments")
}

model UserMemory {
  id        String   @id @default(cuid())
  userId    String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Thread {
  id                  String    @id @default(cuid())
  userId              String
  title               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastMessageAt       DateTime  @default(now())
  conversationSummary String
  messages            Message[]
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastMessageAt])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  role      String
  content   String
  parts     Json
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([userId])
  @@index([createdAt])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}
