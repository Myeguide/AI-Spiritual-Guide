generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model SubscriptionTier {
  id            String         @id @default(cuid())
  name          String         @unique
  type          String         @unique
  totalRequests Int            @map("total_requests")
  price         String
  validityDays  Int            @map("validity_days")
  currency      String         @default("INR")
  description   String?
  features      String[]
  Subscription  Subscription[]

  @@index([name])
  @@index([type])
  @@map("subscription_tiers")
}

model User {
  id          String    @id @default(cuid())
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  email       String    @unique
  age         Int?
  dob         DateTime? @map("dob")
  phoneNumber String    @unique @map("phone_number")
  password    String    @default("")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Current active subscription tracking
  activeSubscriptionId String? @unique @map("active_subscription_id")
  requestsUsedLifetime Int     @default(0) @map("requests_used_lifetime")

  // Relations
  Thread           Thread[]
  userMemory       UserMemory?
  payments         Payment[]
  Subscription     Subscription[]
  OtpCode          OtpCode[]
  paymentMethods   PaymentMethod[]
  whatsappMessages WhatsAppMessage[]

  // WhatsApp tracking
  whatsappEnabled Boolean @default(false) @map("whatsapp_enabled")

  @@index([email])
  @@index([activeSubscriptionId])
  @@map("users")
}

model OtpCode {
  id          String   @id @default(cuid())
  userId      String?
  phoneNumber String
  code        String
  expiresAt   DateTime
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber])
  @@index([code])
}

model Subscription {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  tierId   String @map("tier_id")
  planType String @map("plan_type")
  amount   String
  currency String @default("INR")

  // Request quota for THIS subscription
  totalRequests Int @map("total_requests")
  requestsUsed  Int @default(0) @map("requests_used")

  // Subscription validity
  startDate   DateTime? @map("start_date")
  expiresAt   DateTime? @map("expires_at")
  cancelledAt DateTime? @map("cancelled_at")

  status    SubscriptionStatus @default(PENDING)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier     SubscriptionTier @relation(fields: [tierId], references: [id], onDelete: Restrict)
  payments Payment[]

  reminderSentAt   DateTime? @map("reminder_sent_at") // 5-day reminder
  expiredEmailSent Boolean   @default(false) @map("expired_email_sent")

  @@index([userId])
  @@index([tierId])
  @@index([status])
  @@index([expiresAt])
  @@map("subscriptions")
}

model Payment {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  subscriptionId    String        @map("subscription_id")
  paymentMethodId   String?       @map("payment_method_id")
  razorpayPaymentId String?       @unique @map("razorpay_payment_id")
  razorpayOrderId   String?       @map("razorpay_order_id")
  razorpaySignature String?       @map("razorpay_signature")
  amount            String
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  method            String?
  description       String?
  notes             Json?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  subscription  Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
  @@index([paymentMethodId])
  @@index([status])
  @@index([razorpayPaymentId])
  @@map("payments")
}

model PaymentMethod {
  id     String            @id @default(cuid())
  userId String            @map("user_id")
  type   PaymentMethodType // card, upi, wallet, netbanking etc.

  cardType        String? @map("card_type") // credit, debit, prepaid
  cardNetwork     String? @map("card_network") // Visa, Mastercard, RuPay, etc.
  cardLast4       String? @map("card_last4") // Last 4 digits
  cardIssuer      String? @map("card_issuer") // Bank name
  cardName        String? @map("card_name") // Name on card (if available)
  cardExpMonth    String? @map("card_exp_month") // Expiry month (MM)
  cardExpYear     String? @map("card_exp_year") // Expiry year (YYYY)
  cardTokenId     String? @unique @map("card_token_id") // Razorpay token ID for saved card
  cardFingerPrint String? @map("card_finger_print") // Unique identifier for card
  customerId      String? @map("customer_id")

  upiVpa String? @map("upi_vpa") // UPI ID (e.g., user@bank)

  bankName String? @map("bank_name")

  walletName String? @map("wallet_name") // Paytm, PhonePe, etc.

  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  nickname  String? // User-friendly name for the payment method
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([userId])
  @@index([userId, isDefault])
  @@index([cardTokenId])
  @@index([customerId])
  @@map("payment_methods")
}

model UserMemory {
  id        String   @id @default(cuid())
  userId    String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Thread {
  id                  String    @id @default(cuid())
  userId              String?
  anonId              String?   @map("anon_id")
  title               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastMessageAt       DateTime  @default(now())
  conversationSummary String
  messages            Message[]
  user                User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastMessageAt])
  @@index([anonId, lastMessageAt])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  userId    String?
  anonId    String?  @map("anon_id")
  role      String
  content   String
  parts     Json
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([userId])
  @@index([anonId])
  @@index([createdAt])
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  phoneNumber String   @map("phone_number")
  direction   String // 'inbound' or 'outbound'
  content     String
  msg91Id     String?  @map("msg91_id")
  status      String   @default("sent")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phoneNumber])
  @@map("whatsapp_messages")
}

model AnonymousUsage {
  id            String   @id @default(cuid())
  identifier    String   @unique
  questionsUsed Int      @default(0) @map("questions_used")
  lastUsedAt    DateTime @default(now()) @map("last_used_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("anonymous_usage")
}

// Optional: Email log for debugging
model EmailLog {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  email    String
  type     String // 'subscription_reminder', 'subscription_expired', etc.
  subject  String
  status   String   @default("sent") // 'sent', 'failed', 'bounced'
  metadata Json?
  sentAt   DateTime @default(now()) @map("sent_at")

  @@index([userId])
  @@index([type])
  @@index([sentAt])
  @@map("email_logs")
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

enum PaymentMethodType {
  CARD
  UPI
  NETBANKING
  WALLET
}
