generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PriorityTier {
  id              String   @id @default(cuid())
  name            String   @unique
  type            String   @unique
  tokensPerMinute Int
  tokensPerMonth  Int
  price           String
  validityDays    Int
  currency        String   @default("INR")
  description     String?
  features        String[]

  @@index([name])
  @@index([type])
}

model User {
  id                    String         @id @default(cuid())
  firstName             String
  lastName              String
  email                 String         @unique
  age                   Int?
  phoneNumber           String         @unique
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  otpCode               String
  minuteResetAt         DateTime       @default(now())
  monthResetAt          DateTime
  subscriptionExpiresAt DateTime?
  tierId                String
  tokensUsedLifetime    Int            @default(0)
  tokensUsedThisMin     Int            @default(0)
  tokensUsedThisMonth   Int            @default(0)
  subscriptions         Subscription[]
  Thread                Thread[]
  tokenHistory          TokenHistory[]
  userMemory            UserMemory?
  payments              Payment[]

  @@index([tierId])
  @@index([email])
  @@index([subscriptionExpiresAt])
}

model TokenHistory {
  id        String   @id @default(cuid())
  userId    String
  tokens    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String             @map("user_id")
  tokensPerMinute Int
  tokensPerMonth  Int
  planType        String             @map("plan_type")
  amount          String
  currency        String             @default("INR")
  startDate       DateTime?          @map("start_date")
  endDate         DateTime?          @map("end_date")
  nextBillingDate DateTime?          @map("next_billing_date")
  cancelledAt     DateTime?          @map("cancelled_at")
  status          SubscriptionStatus @default(PENDING)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  Payment         Payment[]

  @@index([userId])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  subscriptionId    String        @map("subscription_id")
  razorpayPaymentId String?       @unique @map("razorpay_payment_id")
  razorpayOrderId   String?       @map("razorpay_order_id")
  razorpaySignature String?       @map("razorpay_signature")
  amount            String
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  method            String?
  description       String?
  notes             Json?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  subscription      Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([razorpayPaymentId])
  @@map("payments")
}

model UserMemory {
  id        String   @id @default(cuid())
  userId    String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Thread {
  id                  String    @id @default(cuid())
  userId              String
  title               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastMessageAt       DateTime  @default(now())
  conversationSummary String
  messages            Message[]
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastMessageAt])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  role      String
  content   String
  parts     Json
  createdAt DateTime @default(now())
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([userId])
  @@index([createdAt])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}
